          <format attr='border-style' id='story-description_17' value='none' />
          <format attr='border-width' id='story-description_18' value='0' />
          <format attr='border-style' id='story-description_18' value='none' />
        </style-rule>
      </style>
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='97800' id='10' param='vert' removable='false' type-v2='layout-flow' w='98768' x='616' y='1100'>
            <zone h='2476' id='11' type-v2='title' w='98768' x='616' y='1100'>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
              </zone-style>
            </zone>
            <zone h='95324' id='8' param='vert' removable='false' type-v2='layout-flow' w='98768' x='616' y='3576'>
              <zone h='95324' id='1' param='vert' removable='false' type-v2='layout-flow' w='98768' x='616' y='3576'>
                <zone h='13893' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98768' x='616' y='3576' />
                <zone h='81431' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98768' x='616' y='17469'>
                  <flipboard active-id='4' nav-type='caption' show-nav-arrows='true'>
                    <story-points>
                      <story-point caption='1. Introduction' captured-sheet='Choropleth Map' id='1' />
                      <story-point caption='2. Deep Dive' captured-sheet='Regression Plot' id='2' />
                      <story-point caption='3. Operational Risk' captured-sheet='Boxplot Analysis' id='3' />
                      <story-point caption='Interactive Exploration' captured-sheet='Advanced Customer Analytics Dashboard' id='4' />
                      <story-point caption='Conclusion' captured-sheet='' id='5' />
                    </story-points>
                  </flipboard>
                </zone>
              </zone>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='36726' hidden='true' id='6' story-point-id='1' type-v2='text' w='29176' x='1232' y='58459'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='16'>Our customer base is geographically diverse, with clear concentrations in California. This overview helps us identify where our primary marketing focus currently lies</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='4539' hidden='true' id='12' story-point-id='1' type-v2='text' w='25789' x='2232' y='15131'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#da372d' fontname='Benton Sans Book' fontsize='20'>The Customer Landscape</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='9629' hidden='true' id='13' story-point-id='2' type-v2='text' w='33333' x='1232' y='13893'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#d33e2a' fontname='Benton Sans Book' fontsize='20'>Income vs. Customer Lifetime Value</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='28061' hidden='true' id='14' story-point-id='2' type-v2='text' w='48037' x='49808' y='35076'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='16'>We investigated whether customer income levels influence long-term loyalty (CLV). While we found a statistically significant link, the connection is practically weak (</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Google Sans Text,sans-serif' fontsize='16'>$R^2$</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='16'> is very low). This suggests that high-income customers aren&apos;t necessarily our most valuable assets</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='4814' hidden='true' id='15' story-point-id='3' type-v2='text' w='16089' x='1386' y='11967'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#da372d' fontname='Benton Sans Book' fontsize='22'>Claim Analysis</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='37552' hidden='true' id='16' story-point-id='3' type-v2='text' w='54119' x='29638' y='30536'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='16'>We examined claims by vehicle size. While median claim amounts remain consistent, we identified critical outliers—individual customers who file claims far exceeding the norm. These represent our highest financial risk</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='4814' hidden='true' id='17' story-point-id='5' type-v2='text' w='30947' x='3233' y='12655'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#da372d' fontname='Benton Sans Book' fontsize='22'>Strategic Recommendations</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='44842' hidden='true' id='18' story-point-id='5' type-v2='text' w='78753' x='9854' y='37964'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#d33e2a' fontname='Benton Sans Book' fontsize='22'>In conclusion:</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='16'>Stop relying solely on income as a predictor for CLV.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='16'>Start a targeted investigation into the &apos;outlier&apos; claims identified in our boxplot.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='16'>Focus resources on regions with high claim frequency to stabilize loss ratios.&quot;</run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{6034BCC6-23E6-4C95-BBA2-B13AC3877562}' />
    </dashboard>
