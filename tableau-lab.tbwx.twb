    <worksheet name='Regression Plot'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontname='Tableau Bold' fontsize='14'>Regression Plot </run>
            <run bold='true' fontcolor='#1f1f1f' fontname='Tableau Bold' fontsize='14'>Statistical Interpretation</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Google Sans Text,sans-serif' fontsize='12'>P-value ($0.0198749$):</run>
            <run fontcolor='#000000' fontname='Google Sans Text,sans-serif' fontsize='12'> Since this value is </run>
            <run bold='true' fontcolor='#000000' fontname='Google Sans Text,sans-serif' fontsize='12'>less than $0.05$</run>
            <run fontcolor='#000000' fontname='Google Sans Text,sans-serif' fontsize='12'>, you can conclude that the relationship between Income and Customer Lifetime Value is </run>
            <run bold='true' fontcolor='#000000' fontname='Google Sans Text,sans-serif' fontsize='12'>statistically significant</run>
            <run fontcolor='#000000' fontname='Google Sans Text,sans-serif' fontsize='12'>. There is less than a 2% probability that this relationship occurred by random chance.</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Google Sans Text,sans-serif' fontsize='12'>R-Squared ($0.0005937$):</run>
            <run fontcolor='#000000' fontname='Google Sans Text,sans-serif' fontsize='12'> This value is very low (less than $0.1\%$).</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Google Sans Text,sans-serif' fontsize='12' italic='true'>Interpretation:</run>
            <run fontcolor='#000000' fontname='Google Sans Text,sans-serif' fontsize='12'> While the relationship is statistically significant due to the large sample size ($9,134$ observations), it is </run>
            <run bold='true' fontcolor='#000000' fontname='Google Sans Text,sans-serif' fontsize='12'>practically very weak</run>
            <run fontcolor='#000000' fontname='Google Sans Text,sans-serif' fontsize='12'>. Income explains only $0.06\%$ of the variation in Customer Lifetime Value. This suggests that other factors (such as policy type, location, or customer history) are much more important drivers of CLV than income alone.</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='we_fn_use_c_marketing_customer_value_analysis' name='federated.0vsig910yvthox1bkwdj511bsten' />
          </datasources>
          <datasource-dependencies datasource='federated.0vsig910yvthox1bkwdj511bsten'>
            <column datatype='real' name='[Customer Lifetime Value]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Income]' role='measure' type='quantitative' />
            <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column-instance column='[Customer Lifetime Value]' derivation='Sum' name='[sum:Customer Lifetime Value:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Income]' derivation='Sum' name='[sum:Income:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0vsig910yvthox1bkwdj511bsten].[Action (State)]'>
            <groupfilter function='level-members' level='[State]' user:ui-action-filter='[Action2_3640733FA1EB488C9966E54C39104328]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <slices>
            <column>[federated.0vsig910yvthox1bkwdj511bsten].[Action (State)]</column>
          </slices>
          <aggregation value='false' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <trendline enable-confidence-bands='false' enable-instant-analytics='true' enabled='true' exclude-color='false' exclude-intercept='false' fit='linear' />
          </pane>
        </panes>
        <rows>[federated.0vsig910yvthox1bkwdj511bsten].[sum:Customer Lifetime Value:qk]</rows>
        <cols>[federated.0vsig910yvthox1bkwdj511bsten].[sum:Income:qk]</cols>
      </table>
